{
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^4.0",
        "mockery/mockery": "^1.6"
    },

    "scripts": {
        "test": "clear && vendor/bin/phpunit --testdox --verbose -c /app/tests/phpunit.xml.dist",
        "test:verbose": "vendor/bin/phpunit --verbose -c /app/tests/phpunit.xml.dist",
        "test:coverage": "vendor/bin/phpunit --coverage-text -c /app/tests/phpunit.xml.dist",
        "test:debug": "vendor/bin/phpunit --debug -c /app/tests/phpunit.xml.dist"
    }
}
